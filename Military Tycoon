else
                        part = button:FindFirstChildWhichIsA("BasePart", true)
                    end

                    if part then
                        root.CFrame = part.CFrame + Vector3.new(0,5,0)
                        task.wait(0.8)
                    end
                end

                task.wait(1)

local collectButton = myTycoon
                    :WaitForChild("Models")
                    :WaitForChild("TotalGiver")
                    :WaitForChild("CollectButton")

                root.CFrame = collectButton.CFrame + Vector3.new(0,5,0)

                task.wait(1)
            end
        end)
    end
end)

