--Buttons

  local AutoUpgrade = false

local function isBlacklisted(name)
    if name == "NewBase_SecondFloor_Window2"
        or name == "SuperSoldier"
        or name == "DoubleBlueprints"
        or name == "AttackHusky" then
        return true
    end

    if string.match(name, "^Vault_") then
        return true
    end

    if string.match(name, "^DBDiamond_Statue") then
        return true
    end

    return false
end

Tab1Section:NewToggle("Auto Upgrade Tycoon", "Free", function(state)
    AutoUpgrade = state

    if state then
        task.spawn(function()
            while AutoUpgrade do
                local Players = game:GetService("Players")
                local player = Players.LocalPlayer

                local tycoons = workspace:WaitForChild("PlayerTycoons")
                local myTycoon

                for _, tycoon in pairs(tycoons:GetChildren()) do
                    if tycoon.Name == player.Name then
                        myTycoon = tycoon
                        break
                    end
                end

                if not myTycoon then return end

                local buttonFolder = myTycoon:WaitForChild("ButtonFolder")
                local character = player.Character or player.CharacterAdded:Wait()
                local root = character:WaitForChild("HumanoidRootPart")

                local specialButton = buttonFolder:FindFirstChild("NewBase_SecondFloor_Window2")

                if specialButton then
                    local part = specialButton:IsA("BasePart") and specialButton or specialButton:FindFirstChildWhichIsA("BasePart", true)

                    while AutoUpgrade and specialButton.Parent do
                        root.CFrame = part.CFrame + Vector3.new(0,5,0)
                        task.wait(0.3)
                    end
                end

                local buttons = {}

                for _, button in ipairs(buttonFolder:GetChildren()) do
                    if not AutoUpgrade then break end

                   if isBlacklisted(button.Name) then
    continue
end
                    local part
                    if button:IsA("BasePart") then
                        part = button
                    else
                        part = button:FindFirstChildWhichIsA("BasePart", true)
                    end

                    if part then
                        table.insert(buttons, part)
                    end
                end

                table.sort(buttons, function(a, b)
                    return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
                end)

                for _, part in ipairs(buttons) do
                    if not AutoUpgrade then break end
                    root.CFrame = part.CFrame + Vector3.new(0,5,0)
                    task.wait(0.8)
                end

                task.wait(1)

                local collectButton = myTycoon
                    :WaitForChild("Models")
                    :WaitForChild("TotalGiver")
                    :WaitForChild("CollectButton")

                root.CFrame = collectButton.CFrame + Vector3.new(0,5,0)

                task.wait(1)
            end
        end)
    end
end)

